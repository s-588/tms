	<htmx-partial hx-target="#transports-add-content">
		<form
			hx-post="/transports"
			hx-push-url="true"
			id="transports-add-content"
			class="flex gap-6 flex-col"
		>
			{{ modelField := userForm["model"] }}
			@form.Item() {
				@form.Label(form.LabelProps{ For: "transports-add-model" }) { Model }
				if modelField.Err == nil {
					@input.Input(input.Props{
						ID:          "transports-add-model",
						Name:        "model",
						Type:        input.TypeText,
						Value:       modelField.Value,
						Placeholder: "Volvo FH16",
					})
				} else {
					@input.Input(input.Props{
						ID:          "transports-add-model",
						Name:        "model",
						Type:        input.TypeText,
						Value:       modelField.Value,
						Placeholder: "Volvo FH16",
						HasError:    true,
					})
					@form.Description() { Enter transport model. }
					@form.Message(form.MessageProps{ Variant: form.MessageVariantError }) {
						{ modelField.Err.Error() }
					}
				}
			}

			{{ licenseField := userForm["license_plate"] }}
			@form.Item() {
				@form.Label(form.LabelProps{ For: "transports-add-license" }) { License Plate (optional) }
				if licenseField.Err == nil {
					@input.Input(input.Props{
						ID:          "transports-add-license",
						Name:        "license_plate",
						Type:        input.TypeText,
						Value:       licenseField.Value,
						Placeholder: "ABC-123",
					})
				} else {
					@input.Input(input.Props{
						ID:          "transports-add-license",
						Name:        "license_plate",
						Type:        input.TypeText,
						Value:       licenseField.Value,
						Placeholder: "ABC-123",
						HasError:    true,
					})
					@form.Description() { Enter license plate (optional). }
					@form.Message(form.MessageProps{ Variant: form.MessageVariantError }) {
						{ licenseField.Err.Error() }
					}
				}
			}

			{{ payloadField := userForm["payload_capacity"] }}
			@form.Item() {
				@form.Label(form.LabelProps{ For: "transports-add-payload" }) { Payload Capacity (kg) }
				if payloadField.Err == nil {
					@input.Input(input.Props{
						ID:          "transports-add-payload",
						Name:        "payload_capacity",
						Type:        input.TypeNumber,
						Value:       payloadField.Value,
						Placeholder: "20000",
					})
				} else {
					@input.Input(input.Props{
						ID:          "transports-add-payload",
						Name:        "payload_capacity",
						Type:        input.TypeNumber,
						Value:       payloadField.Value,
						Placeholder: "20000",
						HasError:    true,
					})
					@form.Description() { Enter payload capacity in kilograms. }
					@form.Message(form.MessageProps{ Variant: form.MessageVariantError }) {
						{ payloadField.Err.Error() }
					}
				}
			}

			{{ fuelField := userForm["fuel_consumption"] }}
			@form.Item() {
				@form.Label(form.LabelProps{ For: "transports-add-fuel" }) { Fuel Consumption (L/100km) }
				if fuelField.Err == nil {
					@input.Input(input.Props{
						ID:          "transports-add-fuel",
						Name:        "fuel_consumption",
						Type:        input.TypeNumber,
						Value:       fuelField.Value,
						Placeholder: "30",
					})
				} else {
					@input.Input(input.Props{
						ID:          "transports-add-fuel",
						Name:        "fuel_consumption",
						Type:        input.TypeNumber,
						Value:       fuelField.Value,
						Placeholder: "30",
						HasError:    true,
					})
					@form.Description() { Enter fuel consumption in liters per 100km. }
					@form.Message(form.MessageProps{ Variant: form.MessageVariantError }) {
						{ fuelField.Err.Error() }
					}
				}
			}

			@button.Button(button.Props{
				Type:    button.TypeSubmit,
				Variant: button.VariantDefault,
			}) {
				Add
			}
		</form>
	</htmx-partial>
}

// ---------------------------------------------------------------------
// Pagination
// ---------------------------------------------------------------------
templ TransportsPagination(page, totalPages int32, filter models.TransportFilter) {
	{{ p := pagination.CreatePagination(int(page), int(totalPages), 4) }}
	{{ query := buildQueryString(filter) }}
	@pagination.Pagination() {
		@pagination.Content() {
			@pagination.Item() {
				@pagination.Previous(pagination.PreviousProps{
					Attributes: templ.Attributes{
						"hx-target":   "#transports-table",
						"hx-push-url": "true",
						"hx-get":      buildTransportsURL(query, p.CurrentPage-1),
					},
					Disabled: !p.HasPrevious,
					Label:    "Previous",
				})
			}
			if p.Pages[0] > 1 {
				@pagination.Item() {
					@pagination.Link(pagination.LinkProps{
						Attributes: templ.Attributes{
							"hx-target":   "#transports-table",
							"hx-push-url": "true",
							"hx-get":      buildTransportsURL(query, 1),
						},
					}) { 1 }
				}
				if p.Pages[0] > 2 {
					@pagination.Item() { @pagination.Ellipsis() }
				}
			}
			for _, pg := range p.Pages {
				@pagination.Item() {
					@pagination.Link(pagination.LinkProps{
						Attributes: templ.Attributes{
							"hx-target":   "#transports-table",
							"hx-push-url": "true",
							"hx-get":      buildTransportsURL(query, pg),
						},
						IsActive: pg == p.CurrentPage,
					}) { { fmt.Sprint(pg) } }
				}
			}
			if p.Pages[len(p.Pages)-1] < p.TotalPages {
				if p.Pages[len(p.Pages)-1] < p.TotalPages-1 {
					@pagination.Item() { @pagination.Ellipsis() }
				}
				@pagination.Item() {
					@pagination.Link(pagination.LinkProps{
						Attributes: templ.Attributes{
							"hx-target":   "#transports-table",
							"hx-push-url": "true",
							"hx-get":      buildTransportsURL(query, p.TotalPages),
						},
					}) { { fmt.Sprint(p.TotalPages) } }
				}
			}
			@pagination.Item() {
				@pagination.Next(pagination.NextProps{
					Attributes: templ.Attributes{
						"hx-target":   "#transports-table",
						"hx-push-url": "true",
						"hx-get":      buildTransportsURL(query, p.CurrentPage+1),
					},
					Disabled: !p.HasNext,
					Label:    "Next",
				})
			}
		}
	}
}

// ---------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------
func buildQueryString(filter models.TransportFilter) string {
	params := []string{}
	if filter.Model.Set && filter.Model.Value != "" {
		params = append(params, "model="+filter.Model.Value)
	}
	if filter.LicensePlate.Set && filter.LicensePlate.Value != "" {
		params = append(params, "license_plate="+filter.LicensePlate.Value)
	}
	if filter.PayloadCapacityMin.Set {
		params = append(params, "payload_min="+strconv.Itoa(int(filter.PayloadCapacityMin.Value)))
	}
	if filter.PayloadCapacityMax.Set {
		params = append(params, "payload_max="+strconv.Itoa(int(filter.PayloadCapacityMax.Value)))
	}
	if filter.FuelConsumptionMin.Set {
		params = append(params, "fuel_min="+strconv.Itoa(int(filter.FuelConsumptionMin.Value)))
	}
	if filter.FuelConsumptionMax.Set {
		params = append(params, "fuel_max="+strconv.Itoa(int(filter.FuelConsumptionMax.Value)))
	}
	if filter.SortBy.Set {
		params = append(params, "sort="+filter.SortBy.Value)
	}
	if filter.SortOrder.Set {
		params = append(params, "order="+filter.SortOrder.Value)
	}
	return strings.Join(params, "&")
}

func buildTransportsURL(baseQuery string, page int) string {
	if baseQuery == "" {
		return fmt.Sprintf("/transports?page=%d", page)
	}
	return fmt.Sprintf("/transports?%s&page=%d", baseQuery, page)
}